{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Mongo": {
    "ConnectionString": "mongodb://localhost:27017",
    "DatabaseName": "fiscalflow"
  },
  "RabbitMq": {
    "HostName": "localhost",
    "Port": 5672,
    "UserName": "guest",
    "Password": "guest",
    "QueueName": "fiscalflow.documents"
  },
  "FiscalDocumentUpload": {
    "MaxFileSizeBytes": 2097152
  },
  "Security": {
    "Enabled": false,
    "Issuer": "FiscalFlow",
    "Audience": "FiscalFlow.Api",
    "ClockSkewSeconds": 60,
    "RateLimitPermitLimit": 60,
    "RateLimitWindowSeconds": 60
  },
  "AllowedHosts": "*"
}
