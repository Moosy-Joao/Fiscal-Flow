{
  "MongoDb": {
    "ConnectionString": "mongodb://localhost:27017",
    "DatabaseName": "fiscalflow-security-tests",
    "InitializeIndexes": false
  },
  "RabbitMq": {
    "Enabled": false
  },
  "BackgroundJobs": {
    "Enabled": false
  },
  "Security": {
    "Enabled": true,
    "Issuer": "FiscalFlow.Tests",
    "Audience": "FiscalFlow.Api",
    "SigningKey": "fiscal-flow-tests-signing-key-2026-secure",
    "ClockSkewSeconds": 0,
    "RateLimitPermitLimit": 2,
    "RateLimitWindowSeconds": 60
  }
}
