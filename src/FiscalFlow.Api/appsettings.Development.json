{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "MongoDb": {
    "ConnectionString": "mongodb://localhost:27017",
    "DatabaseName": "fiscalflow",
    "InitializeIndexes": true
  },
  "RabbitMq": {
    "HostName": "localhost",
    "Port": 5672,
    "UserName": "fiscalflow",
    "Password": "fiscalflow",
    "VirtualHost": "/",
    "ExchangeName": "fiscalflow.documents",
    "QueueName": "fiscalflow.documents.process",
    "RoutingKey": "fiscal-document.received",
    "RetryExchangeName": "fiscalflow.documents.retry",
    "RetryQueueName": "fiscalflow.documents.process.retry",
    "RetryRoutingKey": "fiscal-document.received.retry",
    "DeadLetterExchangeName": "fiscalflow.documents.dead-letter",
    "DeadLetterQueueName": "fiscalflow.documents.process.dead-letter",
    "DeadLetterRoutingKey": "fiscal-document.received.dead-letter",
    "RetryDelayMilliseconds": 5000,
    "MaxRetryAttempts": 3
  }
}
